{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "inputs": ["src/**/*"],
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "declarations/**"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "outputs": ["dist/**/*"],
      "dependsOn": ["^build"]
    }
  }
}
