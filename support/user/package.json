{
  "name": "@sportipedia/user",
  "private": true,
  "description": "Sportipedia User Supporting Domain (including Auth)",
  "keywords": [
    "ember-addon"
  ],
  "author": "Thomas Gossmann",
  "imports": {
    "#/": "./src/index.ts",
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./declarations/*.d.ts",
      "default": "./dist/*"
    },
    "./addon-main.js": "./addon-main.cjs"
  },
  "files": [
    "addon-main.cjs",
    "dist",
    "locales",
    "declarations"
  ],
  "scripts": {
    "build": "pnpm run '/^build:.*/'",
    "build:js": "rollup --config",
    "build:declarations": "glint --declaration --project tsconfig.publish.json",
    "dev": "vite dev",
    "lint": "pnpm run '/^lint:(?!.*(fix)).*$/'",
    "lint:fix": "pnpm run '/^lint:[^:]*:fix/'",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "glint",
    "prepack": "pnpm build",
    "release": "release-it",
    "start": "pnpm run '/^start:.*/'",
    "start:js": "rollup --config --watch",
    "start:declarations": "ember-tsc --declaration --project tsconfig.publish.json --watch",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.10.0",
    "@hokulea/ember": "^0.10.2",
    "better-auth": "^1.3.7",
    "decorator-transforms": "^2.3.0",
    "ember-ability": "^1.0.0",
    "ember-better-auth": "^0.0.1",
    "ember-command": "^2.0.7",
    "ember-intl": "workspace:*",
    "ember-link": "^3.5.0",
    "ember-strict-application-resolver": "^0.1.0",
    "ember-truth-helpers": "^4.0.3",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/eslint-parser": "^7.27.5",
    "@babel/plugin-transform-typescript": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.27.6",
    "@ember/app-tsconfig": "^1.0.3",
    "@ember/library-tsconfig": "^1.1.3",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.18.1",
    "@embroider/vite": "^1.1.5",
    "@glimmer/component": "^2.0.0",
    "@glint/ember-tsc": "^1.0.4",
    "@glint/template": "^1.6.2",
    "@gossi/config-eslint": "^1.3.0",
    "@gossi/config-prettier": "^1.1.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/qunit": "^2.19.12",
    "@warp-drive/ember": "5.8.0",
    "babel-plugin-ember-template-compilation": "^3.0.0",
    "ember-qunit": "^9.0.3",
    "ember-resolver": "^13.1.1",
    "ember-source": "~6.8.0",
    "eslint": "^9.32.0",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-qunit": "^8.1.2",
    "glimmer-scoped-css": "^0.8.1",
    "prettier": "^3.5.3",
    "qunit": "^2.24.1",
    "rollup": "^4.44.0",
    "testem": "^3.16.0",
    "typescript": "^5.9.2",
    "unplugin-icons": "^22.1.0",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs"
  }
}
