{
  "name": "@sportipedia/user",
  "private": true,
  "description": "Sportipedia User Supporting Domain (including Auth)",
  "keywords": [
    "ember-addon"
  ],
  "author": "Thomas Gossmann",
  "type": "module",
  "imports": {
    "#/": "./src/index.ts",
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./registry": {
      "types": "./declarations/registry.d.ts",
      "default": "./dist/registry.mjs"
    }
  },
  "files": [
    "dist",
    "declarations",
    "locales"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "vite dev",
    "lint": "pnpm run '/^lint:(?!.*(fix)).*$/'",
    "lint:fix": "pnpm run '/^lint:[^:]*:fix/'",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc",
    "prepack": "pnpm build",
    "start": "tsdown --watch",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.10.0",
    "@sportipedia/ui": "workspace:*",
    "@hokulea/ember": "catalog:lib",
    "better-auth": "catalog:lib",
    "decorator-transforms": "catalog:build",
    "ember-ability": "catalog:ember",
    "ember-better-auth": "catalog:ember",
    "ember-command": "catalog:ember",
    "ember-intl": "workspace:*",
    "ember-link": "catalog:ember",
    "ember-strict-application-resolver": "catalog:ember",
    "ember-truth-helpers": "catalog:ember",
    "valibot": "^1.1.0"
  },
  "peerDependencies": {
    "@glimmer/component": "catalog:ember",
    "ember-concurrency": "catalog:ember",
    "better-auth": "catalog:lib"
  },
  "devDependencies": {
    "@babel/core": "catalog:build",
    "@babel/eslint-parser": "catalog:build",
    "@babel/plugin-transform-typescript": "catalog:build",
    "@babel/preset-typescript": "catalog:build",
    "@babel/runtime": "catalog:build",
    "@ember/app-tsconfig": "catalog:ember",
    "@ember/library-tsconfig": "catalog:ember",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/addon-dev": "catalog:ember",
    "@embroider/compat": "catalog:ember",
    "@embroider/core": "catalog:ember",
    "@embroider/macros": "catalog:ember",
    "@embroider/vite": "catalog:ember",
    "@glimmer/component": "catalog:ember",
    "@glint/ember-tsc": "catalog:ember",
    "@glint/template": "catalog:ember",
    "@glint/tsserver-plugin": "catalog:ember",
    "@gossi/config-eslint": "catalog:lint",
    "@gossi/config-prettier": "catalog:lint",
    "@gossi/config-stylelint": "catalog:lint",
    "@gossi/config-template-lint": "catalog:lint",
    "@rollup/plugin-babel": "catalog:build",
    "@types/qunit": "catalog:types",
    "@warp-drive/ember": "catalog:ember",
    "babel-plugin-ember-template-compilation": "catalog:build",
    "better-auth": "catalog:lib",
    "ember-qunit": "^9.0.3",
    "ember-resolver": "catalog:ember",
    "ember-scoped-css": "catalog:ember",
    "ember-source": "catalog:ember",
    "eslint": "catalog:lint",
    "eslint-plugin-ember": "catalog:lint",
    "eslint-plugin-qunit": "catalog:lint",
    "prettier": "catalog:lint",
    "qunit": "^2.24.1",
    "rollup": "^4.44.0",
    "testem": "^3.16.0",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "unplugin-icons": "catalog:icons",
    "vite": "catalog:build"
  },
  "engines": {
    "node": ">=24"
  }
}
