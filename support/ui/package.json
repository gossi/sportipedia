{
  "name": "@sportipedia/ui",
  "private": true,
  "description": "Sportipedia User Supporting Domain (including Auth)",
  "keywords": [
    "ember-addon"
  ],
  "author": "Thomas Gossmann",
  "type": "module",
  "imports": {
    "#/": "./src/index.ts",
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "declarations",
    "locales"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "vite dev",
    "lint": "pnpm run '/^lint:(?!.*(fix)).*$/'",
    "lint:fix": "pnpm run '/^lint:[^:]*:fix/'",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc",
    "prepack": "pnpm build",
    "start": "tsdown --watch",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@hokulea/ember": "^0.13.0",
    "decorator-transforms": "^2.3.0",
    "ember-strict-application-resolver": "^0.1.0",
    "ember-truth-helpers": "^4.0.3",
    "ua-parser-js": "^2.0.6"
  },
  "peerDependencies": {
    "@glimmer/component": "^2.0.0",
    "ember-concurrency": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/eslint-parser": "^7.27.5",
    "@babel/plugin-transform-typescript": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.27.6",
    "@ember/app-tsconfig": "^1.0.3",
    "@ember/library-tsconfig": "^1.1.3",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.18.1",
    "@embroider/vite": "^1.1.5",
    "@glimmer/component": "^2.0.0",
    "@glint/ember-tsc": "^1.0.7",
    "@glint/template": "^1.7.2",
    "@glint/tsserver-plugin": "^2.0.7",
    "@gossi/config-eslint": "^1.3.1",
    "@gossi/config-prettier": "^1.1.1",
    "@gossi/config-stylelint": "^1.1.1",
    "@gossi/config-template-lint": "^1.2.0",
    "@iconify-json/logos": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.43",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/qunit": "^2.19.12",
    "@warp-drive/ember": "5.8.0",
    "babel-plugin-ember-template-compilation": "^3.0.0",
    "ember-qunit": "^9.0.3",
    "ember-resolver": "^13.1.1",
    "ember-scoped-css": "gossi/ember-scoped-css#ddc04c49fc79985ae2281a5273fe1460c4a30adc&path:/ember-scoped-css",
    "ember-source": "~6.8.0",
    "eslint": "^9.32.0",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-qunit": "^8.1.2",
    "prettier": "^3.5.3",
    "qunit": "^2.24.1",
    "rollup": "^4.44.0",
    "testem": "^3.16.0",
    "tsdown": "^0.16.0",
    "typescript": "^5.9.2",
    "unplugin-icons": "^22.1.0",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  }
}
