{
  "name": "ember-intl",
  "private": true,
  "description": "Vite version of ember-intl",
  "author": "Thomas Gossmann",
  "type": "module",
  "imports": {
    "#/": "./src/index.ts",
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    },
    "./registry": {
      "types": "./dist/registry.d.mts",
      "default": "./dist/registry.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "vite dev",
    "lint": "pnpm run '/^lint:(?!.*(fix)).*$/'",
    "lint:fix": "pnpm run '/^lint:[^:]*:fix/'",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "prepack": "pnpm build",
    "start": "tsdown --watch",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@formatjs/intl": "^3.1.6",
    "decorator-transforms": "^2.3.0",
    "dot-prop": "^9.0.0",
    "ember-strict-application-resolver": "^0.1.0",
    "globby": "^14.1.0",
    "js-yaml": "^4.1.0"
  },
  "peerDependencies": {
    "ember-resources": "^7.0.7"
  },
  "devDependencies": {
    "@ember/app-tsconfig": "^1.0.3",
    "@ember/library-tsconfig": "^1.1.3",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.18.1",
    "@embroider/vite": "^1.1.5",
    "@glint/ember-tsc": "^1.0.7",
    "@glint/template": "^1.7.2",
    "@glint/tsserver-plugin": "^2.0.7",
    "@gossi/config-eslint": "^1.1.0",
    "@gossi/config-prettier": "^1.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/qunit": "^2.19.12",
    "ember-qunit": "^9.0.3",
    "ember-resources": "^7.0.7",
    "ember-source": "~6.5.0",
    "eslint": "^9.32.0",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-qunit": "^8.1.2",
    "prettier": "^3.5.3",
    "qunit": "^2.24.1",
    "temporal-polyfill": "^0.3.0",
    "temporal-spec": "^0.3.0",
    "testem": "^3.16.0",
    "tsdown": "^0.16.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  }
}
