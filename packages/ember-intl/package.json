{
  "name": "ember-intl",
  "private": true,
  "description": "Vite version of ember-intl",
  "keywords": [
    "ember-addon"
  ],
  "author": "Thomas Gossmann",
  "imports": {
    "#/": "./src/index.ts",
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./declarations/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./types": {
      "types": "./declarations/types.d.ts"
    },
    "./addon-main.js": "./addon-main.cjs"
  },
  "files": [
    "addon-main.cjs",
    "dist",
    "declarations"
  ],
  "scripts": {
    "build": "rollup --config",
    "dev": "vite dev",
    "lint": "pnpm run '/^lint:(?!.*(fix)).*$/'",
    "lint:fix": "pnpm run '/^lint:[^:]*:fix/'",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "glint",
    "prepack": "pnpm build",
    "release": "release-it",
    "start": "rollup --config --watch",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.10.0",
    "@formatjs/intl": "^3.1.6",
    "decorator-transforms": "^2.3.0",
    "dot-prop": "^9.0.0",
    "globby": "^14.1.0",
    "js-yaml": "^4.1.0"
  },
  "peerDependencies": {
    "ember-resources": "^7.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/eslint-parser": "^7.27.5",
    "@babel/plugin-transform-typescript": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.27.6",
    "@ember/app-tsconfig": "^1.0.3",
    "@ember/library-tsconfig": "^1.1.3",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.18.1",
    "@embroider/vite": "^1.1.5",
    "@glint/ember-tsc": "^1.0.4",
    "@glint/template": "^1.6.2",
    "@gossi/config-eslint": "^1.1.0",
    "@gossi/config-prettier": "^1.0.1",
    "@gossi/config-targets": "^1.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/qunit": "^2.19.12",
    "babel-plugin-ember-template-compilation": "^3.0.0",
    "ember-qunit": "^9.0.3",
    "ember-resolver": "^13.1.1",
    "ember-resources": "^7.0.6",
    "ember-source": "~6.5.0",
    "eslint": "^9.32.0",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-qunit": "^8.1.2",
    "prettier": "^3.5.3",
    "qunit": "^2.24.1",
    "rollup": "^4.44.0",
    "rollup-plugin-copy": "^3.5.0",
    "testem": "^3.16.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs"
  }
}
