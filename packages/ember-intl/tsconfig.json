{
  "extends": "@ember/app-tsconfig",
  "glint": {
    "environment": [
      "ember-loose"
    ]
  },
  "include": [
    "src",
    "tests",
    "types"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "#/": [
        "./src/index.ts"
      ],
      "#/*": [
        "./src/*"
      ],
      "#tests/*": [
        "./tests/*"
      ]
    },
    "types": [
      "ember-source/types",
      "@glint/ember-tsc/types",
      "@embroider/core/virtual",
      "vite/client"
    ]
  }
}
