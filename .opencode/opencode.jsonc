{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
  },
  "mcp": {
    "elixir-ls": {
      "type": "local",
      "command": [
        "bash",
        "scripts/start-elixir-ls-mcp.sh"
      ],
      "enabled": true
    }
  },
  "agent": {
    "builder": {
      "color": "primary"
    },
    "domain-designer": {
      "color": "primary"
    },
    "backend-engineer": {
      "color": "primary"
    },
    "software-architect": {
      "color": "primary"
    },
    "reviewer": {
      "color": "primary"
    }
  },
  "reference": {
    "recipes": {
      "path": ".opencode/recipes"
    }
  }
}