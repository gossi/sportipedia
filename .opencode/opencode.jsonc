{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
  },
  "mcp": {
    "elixir-ls": {
      "type": "local",
      "command": [
        "bash",
        "scripts/start-elixir-ls-mcp.sh"
      ],
      "enabled": true
    }
  },
  "agent": {
    "domain-driven-developer": {
      "color": "primary"
    }
  }
}