{
  "extends": "@ember/app-tsconfig",
  "include": [
    "src",
    "tests",
    "types"
  ],
  "compilerOptions": {
    "allowJs": true,
    "target": "esnext",
    "paths": {
      "#/*": [
        "./src/*"
      ],
      "#auth/*": [
        "./src/support/auth/*"
      ],
      "#support/*": [
        "./src/support/*"
      ],
      "#equipment": [
        "./src/domain/equipment/index.ts"
      ],
      "#tests/*": [
        "./tests/*"
      ]
    },
    "types": [
      "ember-source/types",
      "@glint/ember-tsc/types",
      "@embroider/core/virtual",
      "vite/client",
      "ember-intl/types",
      "unplugin-icons/types/ember"
    ]
  }
}