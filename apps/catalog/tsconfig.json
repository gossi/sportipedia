{
  "extends": "@ember/app-tsconfig",
  "include": [
    "src",
    "tests",
    "types"
  ],
  "glint": {
    "environment": [
      "ember-loose",
      "ember-template-imports"
    ]
  },
  "compilerOptions": {
    "allowJs": true,
    "target": "esnext",
    "paths": {
      "#/*": [
        "./src/*"
      ],
      "#tests/*": [
        "./tests/*"
      ]
    },
    "types": [
      "ember-source/types",
      "@embroider/core/virtual",
      "vite/client"
    ]
  }
}